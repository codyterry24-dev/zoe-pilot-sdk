# ZOE Pilot SDK — Environment Variables
# Copy this file to .env and fill in your values
# Never commit your .env file to version control

# Required: Your pilot API key from AXT Labs
# Contact pilot@axtlabs.co to receive your key
ZOE_API_KEY=zoe_pilot_your_key_here

# Optional: Override the default API endpoint
# Default: https://zoe.axtlabs.co/api/v1
ZOE_ENDPOINT=https://zoe.axtlabs.co/api/v1

# Optional: Request timeout in seconds (default: 30)
ZOE_TIMEOUT=30

# Optional: Enable debug logging (true/false)
ZOE_DEBUG=false
